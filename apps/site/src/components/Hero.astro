---
import Button from './Button.astro';
import { componentVariantMarkers } from '../data/site';

interface Props {
  hero: {
    readonly layout?: 'split' | 'immersive' | 'fullscreen-visual';
    readonly eyebrow: string;
    readonly title: string;
    readonly lead: string;
    readonly primaryCta: { readonly label: string; readonly href: string };
    readonly secondaryCta?: { readonly label: string; readonly href: string };
    readonly trust?: readonly {
      icon?: string;
      title: string;
      description: string;
    }[];
    readonly media?: {
      readonly desktop: string;
      readonly mobile?: string;
      readonly alt: string;
      readonly fit?: 'cover' | 'contain';
    };
  };
}

const { hero } = Astro.props;
const cardVariant = componentVariantMarkers.card;
const heroVariant = componentVariantMarkers.hero;
const hasTrustStrip = Boolean(hero.trust && hero.trust.length > 0);
const heroClassName = ['hero', 'hero--fullscreen-visual', heroVariant.className].filter(Boolean).join(' ');
const contentClassName = ['hero__fullscreen-content', !hasTrustStrip && 'hero__fullscreen-content--no-strip']
  .filter(Boolean)
  .join(' ');
const trustItems = hero.trust?.slice(0, 4) ?? [];
const trustIconMap: Record<string, string> = {
  code: '▣',
  brand: '◇',
  marketing: '↗',
  support: '◎',
};
const resolveTrustIcon = (icon?: string) => trustIconMap[icon ?? ''] ?? '•';
---
<section class={heroClassName} data-hero-layout="fullscreen-visual" aria-labelledby="hero-title" {...heroVariant.dataAttrs}>
  <div class="hero__fullscreen-shell">
    <div class={contentClassName}>
      <div class="hero__fullscreen-copy">
        <p class="hero__eyebrow">{hero.eyebrow}</p>
        <h1 id="hero-title">{hero.title}</h1>
        <p class="hero__lead">{hero.lead}</p>
        <div class="hero__actions">
          <Button href={hero.primaryCta.href}>{hero.primaryCta.label}</Button>
          {hero.secondaryCta && <Button href={hero.secondaryCta.href} variant="secondary">{hero.secondaryCta.label}</Button>}
        </div>
      </div>

      <div class="hero__fullscreen-visual">
        <picture class="hero__fullscreen-media" data-fit={hero.media?.fit ?? 'cover'}>
          <source
            media="(max-width: 768px)"
            srcset={hero.media?.mobile ?? '/assets/demo/fs-hero-mobile-default.webp'}
          />
          <img src={hero.media?.desktop ?? '/assets/demo/fs-hero-default.webp'} alt={hero.media?.alt ?? hero.title} />
        </picture>
      </div>

      {hasTrustStrip && (
        <div class="hero__fullscreen-strip" aria-label="Ключевые преимущества">
          {trustItems.map((item) => (
            <article class:list={['hero__fullscreen-card', cardVariant.className]} {...cardVariant.dataAttrs}>
              <span class="hero__fullscreen-card-icon" aria-hidden="true">{resolveTrustIcon(item.icon)}</span>
              <h3 class="hero__fullscreen-card-title">{item.title}</h3>
              <p class="hero__fullscreen-card-description">{item.description}</p>
            </article>
          ))}
        </div>
      )}
    </div>
  </div>
</section>
