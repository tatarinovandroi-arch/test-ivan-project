---
import Button from './Button.astro';
import SectionHeading from './SectionHeading.astro';
import { componentVariantMarkers } from '../data/site';

interface Props {
  title: string;
  lead: string;
  items: readonly {
    readonly badge: string;
    readonly title: string;
    readonly description: string;
    readonly ctaLabel: string;
  }[];
}

const { title, lead, items } = Astro.props;
const cardVariant = componentVariantMarkers.card;
const sectionVariant = componentVariantMarkers.section;
---
<section class:list={['section', sectionVariant.className]} id="services" {...sectionVariant.dataAttrs}>
  <SectionHeading eyebrow="Услуги" title={title} description={lead} />

  <div class:list={['service-grid', items.length === 4 && 'service-grid--count-4']} data-grid-count={items.length}>
    {items.map((item) => (
      <article class:list={['service-card', cardVariant.className]} {...cardVariant.dataAttrs}>
        <span>{item.badge}</span>
        <h3>{item.title}</h3>
        <p>{item.description}</p>
        <Button href="#contact" class="service-card__cta">{item.ctaLabel}</Button>
      </article>
    ))}
  </div>
</section>
